__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.DS_Store
/.env
/.env.*
!/.env.example

# Local research scratch and draft material that should not be published.
/research/
/RESEARCH_TODO.md
/REFINED_RESEARCH_*.md
/TOP_TIER_RESEARCH_REVIEW.md
/PROVENANCE_NEXT_STEPS.md
/agent_skills_security_research_plan.docx

# Raw run workspaces can contain generated prose from benchmark executions.
# Keep canonical trace/result artifacts tracked, but do not publish raw Markdown
# copies from scratch workspaces.
/results/raw/**/*.md

# Local run sidecars are non-release scratch. Canonical JSON/JSONL traces,
# summaries, and reports stay trackable, but copied workspaces, stdout/stderr,
# and provenance shims can contain local paths or synthetic canaries.
/results/**/stdout.log
/results/**/stderr.log
/results/**/container.id
/results/**/workspace/
/results/**/rp6_policy_shim/
/results/**/python_read_provenance/
/results/**/.env
/results/**/.env.*

# Generated submission exports stay local until an explicit release bundle is
# built and validated.
/submissions/
